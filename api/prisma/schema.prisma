generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id                String             @id @default(cuid())
  name              String
  createdAt         DateTime           @default(now())
  ownedCars         CarOwner[]
  bookings          Booking[]
  pushSubscriptions PushSubscription[]
  spyMessages       SpyMessage[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([memberId])
}

model Car {
  id        String     @id @default(cuid())
  name      String
  plate     String?
  color     String?
  icon      String?
  notes     String?
  createdAt DateTime   @default(now())
  owners    CarOwner[]
  bookings  Booking[]
}

model CarOwner {
  carId    String
  memberId String
  car      Car    @relation(fields: [carId], references: [id], onDelete: Cascade)
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([carId, memberId])
}

enum BookingStatus {
  PENDING
  APPROVED
  DECLINED
  CANCELLED
}

model Booking {
  id            String        @id @default(cuid())
  carId         String
  driverId      String
  startAt       DateTime
  endAt         DateTime
  allDay        Boolean       @default(false)
  purpose       String?
  status        BookingStatus @default(PENDING)
  decidedBy     String?
  decidedAt     DateTime?
  declineReason String?
  createdAt     DateTime      @default(now())
  car           Car           @relation(fields: [carId], references: [id], onDelete: Cascade)
  driver        Member        @relation(fields: [driverId], references: [id])

  @@index([carId, startAt, endAt])
  @@index([status])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

model SpyMessage {
  id        String   @id @default(cuid())
  senderId  String
  sender    Member   @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}
